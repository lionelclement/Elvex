//
// Morphological transformation for French Language
//

#include <iostream>
#define YY_NO_INPUT

%}

%option noyywrap

%s NEXT BEGINLINE

weakPonct	[,;:()'-]
strongPonct	[.!?/]
mesure		mm|cm|m|dm|km|m2|m3|A|[oO]hm|V|VA|gr|[kK]g

%%

<INITIAL>{
  [ \t]+ ;
  [[:lower:]] {
    char cpy = *yytext;
    unput(toupper(cpy));
    BEGIN(BEGINLINE);
  }
  . {yyless(0); BEGIN(BEGINLINE);}
}

<BEGINLINE>. {yyless(0); unput(' '); BEGIN(NEXT);}
	
<NEXT>{	
  \./[^0-9+-] {ECHO; BEGIN(INITIAL);}
  [[:space:]][nNdDjJlL][ea][[:space:]]+/[hH]?([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << yytext[1] << '\'';}
  [[:space:]][mMtTsS][e][[:space:]]+/[hH]?([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << yytext[1] << '\'';}
  [[:space:]][mMtTsS][a][[:space:]]+/[hH]?([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << yytext[1] << "on ";}
  [[:space:]][qQ]ue[[:space:]]+/[hH]?([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << "qu'";}
  [[:space:]][bB]eau[[:space:]]+[aeiouy] {std::cout << yytext[0] << yytext[1] << yytext[2] << "l " << yytext[yyleng-1];}
  [[:space:]][cC]e[[:space:]]+[aeiouy] {std::cout << yytext[0] << yytext[1] << "et " << yytext[yyleng-1];}
  [[:space:]][cC]e[[:space:]]+(茅|猫|锚|毛|卯|茂|么|枚|霉) {std::cout << yytext[0] << yytext[1] << "et " << yytext[yyleng-2] << yytext[yyleng-1];}
  [[:space:]][cC]e[[:space:]]+[hH][aeiouy] {std::cout << yytext[0] << yytext[1] << "et " << yytext[yyleng-2] << yytext[yyleng-1];}
  [[:space:]][cC]e[[:space:]]+[hH](茅|猫|锚|毛|卯|茂|么|枚|霉) {std::cout << yytext[0] << yytext[1] << "et " << yytext[yyleng-3] << yytext[yyleng-2] << yytext[yyleng-1];}
  [[:space:]][dD]e[[:space:]]+les/([[:space:]]+|quel) {std::cout << yytext[0] << yytext[1] << "es";}
  [[:space:]](脿|脌)[[:space:]]+les/([[:space:]]+|quel) {std::cout << yytext[0] << "aux";}
  [[:space:]][dD]e[[:space:]]+le/([[:space:]]+|quel) {std::cout << yytext[0] << yytext[1] << 'u';}
  [[:space:]](脿|脌)[[:space:]]+le/[[:space:]]+ {std::cout << yytext[0] << "au";}
  [[:space:]](脿|脌)[[:space:]]+le/quel {std::cout << yytext[0] << "au";}
  [[:space:]](脿|脌)[[:space:]]+l[ea][[:space:]]+[hH]?/([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << "脿 l'";}
  [[:space:]][sS]i[[:space:]]+[i] {std::cout << yytext[0] << yytext[1] << '\'' << yytext[yyleng-1];}
  [[:space:]][dD]e[[:space:]]+des/[[:space:]]+ {std::cout << yytext[0] << yytext[1] << 'e';}
  [[:space:]][dD]e[[:space:]]+l[ea][[:space:]]+[hH]?/([aAeEiIoOuUyY]|芒|脗|脿|脌|茅|脡|猫|脠|锚|脢|毛|脣|卯|脦|茂|脧|枚|脰|么|脭|眉|脺|没|脹) {std::cout << yytext[0] << "de l'";}
  [[:digit:]][[:space:]]+/{mesure}[[:space:]]+ {yytext[yyleng-1]=0; ECHO;}
  [-][[:space:]]+ {yytext[yyleng-1]=0; ECHO;}
  [ \t]+/[,.;:-] {}
  \n {ECHO; BEGIN(INITIAL);}
  . {ECHO;}
}

%%

int main(){
    yylex();
    return 0;
}
