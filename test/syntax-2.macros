/************************************************************
* Patterns
************************************************************/
@m = [gender:ms];
@f = [gender:fm];
@_1 = [person:one];
@_2 = [person:two];
@_12 = [person:one|two];
@_13 = [person:one|three];
@_3 = [person:three];
@s = [number:sg];
@p = [number:pl];
@_1s = [@_1, @s];
@_2s = [@_2, @s];
@_12s = [@_12, @s];
@_13s = [@_13, @s];
@_3s = [@_3, @s];
@_1p = [@_1, @p];
@_2p = [@_2, @p];
@_3p = [@_3, @p];
@_3ms = [@_3s, @m];
@_3fs = [@_3s, @f];
@ms = [@m, @s];
@mp = [@m, @p];
@fs = [@f, @s];
@fp = [@f, @p];

@P = [vform:tensed, tense:present, mode:indicative];
@P1s = [@P, subj:[@_1s]];
@P2s = [@P, subj:[@_2s]];
@P3s = [@P, subj:[@_3s]];
@P1p = [@P, subj:[@_1p]];
@P2p = [@P, subj:[@_2p]];
@P3p = [@P, subj:[@_3p]];

@hum = [human:true];
@nohum = [human:false];
@anim = [anim:true];
@noanim = [anim:false];

@action = [action:true];
@fact = [fact:true];

@SUBJ_hum = [subj:[@hum]];
@SUBJ_nohum = [subj:[@nohum]];
@SUBJ_anim = [subj:[@anim]];
@SUBJ_noanim = [subj:[@noanim]];
 
@OBJ_hum = [obj:[@hum]];
@OBJ_nohum = [obj:[@nohum]];
@OBJ_anim = [obj:[@anim]];
@OBJ_noanim = [obj:[@noanim]];

@OBJ_action = [obj:[@action]];
@OBJ_fact = [obj:[@fact]];

